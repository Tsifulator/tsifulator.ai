{
  "manifest_version": 3,
  "name": "tsifl — AI Assistant",
  "version": "2.0.0",
  "description": "Agentic AI Sandbox for Financial Analysts — works on any webpage.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://focused-solace-production-6839.up.railway.app/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "tsifl"
  },
  "commands": {
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Toggle tsifl sidebar"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["sidebar.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
