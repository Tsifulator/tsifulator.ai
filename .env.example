# ============================================================
# Tsifulator.ai — Environment Variables
# Copy this file to .env and fill in your real keys.
# NEVER share or commit the .env file.
# ============================================================

# --- AI Brain ---
ANTHROPIC_API_KEY=your_anthropic_key_here

# --- Database (Supabase) ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# --- Usage Controls ---
STARTER_TASK_LIMIT=40       # Max tasks for $20/month tier
PRO_TASK_LIMIT=99999        # Effectively unlimited for $49/month tier

# --- Server ---
BACKEND_PORT=8000
ENV=development
